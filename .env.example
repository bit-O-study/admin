# ─────────────────────────────────────────────────────────────
# heltch-admin 환경변수  ( .env.local 로 복사해 값 채우기 )
# ⚠ service_role 키는 절대 클라이언트에 노출/커밋 금지 (서버 전용)
# ─────────────────────────────────────────────────────────────

# ── 관리자 로그인/세션 (= 헬스앱 Supabase 프로젝트) ──────────────
# 관리자 판별은 이 프로젝트의 admins 테이블(RLS)로 함.
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...

# ── 데이터 접근용 service_role 키 (사이트별) ────────────────────
# 각 Supabase 프로젝트 → Settings → API → service_role secret

# 🍶 양주 가격조회
LIQUOR_SUPABASE_URL=https://xxxx.supabase.co
LIQUOR_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# 🧠 아이큐
IQ_SUPABASE_URL=https://xxxx.supabase.co
IQ_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# 💪 헬스앱  (URL 은 위 NEXT_PUBLIC_SUPABASE_URL 과 같은 프로젝트여도 됨)
HEALTH_SUPABASE_URL=https://xxxx.supabase.co
HEALTH_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── 헬쑤 오늘 방문수(Vercel Web Analytics) ──────────────────────
# 대시보드 "오늘 방문수 - 헬쑤앱" 카드가 이 토큰으로 Vercel Web Analytics 를 읽는다.
# ⚠ 값이 나오려면 헬쑤 프로젝트 Vercel 대시보드에서 Web Analytics 를 ON 해야 함.
#   VERCEL_TOKEN 만 필수(비밀). PROJECT_ID/TEAM_ID 는 코드 기본값이 있어 생략 가능.
VERCEL_TOKEN=vercel_xxx
# HEALTH_VERCEL_PROJECT_ID=prj_qfBy6JxOqnW965uIhGolrwfZ27wZ
# VERCEL_TEAM_ID=team_HzYTymKRx2Wu2CvCxh4BgMMv